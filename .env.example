# Environment variables reference.
# Local dev: copy to .env at repo root.
# Dokploy: set these in the main app's environment settings.

# ─── Database ───
DATABASE_URL="mysql://user:password@host.docker.internal:3306/omni_doc"

# ─── Server ───
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# ─── JWT ───
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── Email (Resend) ───
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM=onboarding@resend.dev

# ─── Frontend URL (used in email links) ───
APP_URL=http://localhost:8080

# ─── Trash & Retention ───
TRASH_RETENTION_DAYS=30
ORG_RETENTION_DAYS=30
ZIP_EXPIRY_HOURS=24

# ─── ONLYOFFICE (optional — set in the main app, not in ONLYOFFICE's app) ───
# ONLYOFFICE_URL: the public URL of your ONLYOFFICE instance
# ONLYOFFICE_JWT_SECRET: must match JWT_SECRET set in the ONLYOFFICE Dokploy app
ONLYOFFICE_URL=
ONLYOFFICE_JWT_SECRET=
