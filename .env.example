# Copy to .env and fill in. Used by docker-compose.

# External MySQL connection string (required by the API / Prisma).
# Use host.docker.internal to reach a MySQL running on your host machine.
DATABASE_URL="mysql://user:password@host.docker.internal:3306/omni_doc"

# Allowed CORS origins (comma-separated, or * for all). Optional.
CORS_ORIGIN=*

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Resend (email)
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM=onboarding@resend.dev

# Frontend URL (for links in emails)
APP_URL=http://localhost:8080

# ONLYOFFICE Document Server (optional — enables docx/xlsx/pptx preview)
ONLYOFFICE_URL=http://localhost:8088
ONLYOFFICE_JWT_SECRET=change-me-to-a-long-random-string
